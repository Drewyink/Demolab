<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Facets — Audit Log</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>
<div class="app-layout">
  <aside class="sidebar">
    <div class="sidebar-logo"><div class="logo-icon">FX</div><div><div class="logo-text">FACETS</div><div class="logo-sub">Config Suite</div></div></div>
    <nav class="sidebar-nav">
      <div class="nav-section-label">Overview</div>
      <a class="nav-item" href="index.html"><span class="nav-icon">◈</span> Dashboard</a>
      <div class="nav-section-label">Employer</div>
      <a class="nav-item" href="groups.html"><span class="nav-icon">🏢</span> Groups / Employers</a>
      <div class="nav-section-label">Configuration</div>
      <a class="nav-item" href="members.html"><span class="nav-icon">👤</span> Members</a>
      <a class="nav-item" href="products.html"><span class="nav-icon">📦</span> Products</a>
      <a class="nav-item" href="plans.html"><span class="nav-icon">📋</span> Plans</a>
      <a class="nav-item" href="benefits.html"><span class="nav-icon">✚</span> Benefits</a>
      <a class="nav-item" href="pricing.html"><span class="nav-icon">💲</span> Pricing</a>
      <div class="nav-section-label">Network</div>
      <a class="nav-item" href="providers.html"><span class="nav-icon">🏥</span> Providers</a>
      <div class="nav-section-label">Operations</div>
      <a class="nav-item" href="claims.html"><span class="nav-icon">📄</span> Claims</a>
      <a class="nav-item" href="authorizations.html"><span class="nav-icon">🔐</span> Authorizations</a>
      <a class="nav-item active" href="audit.html"><span class="nav-icon">🔍</span> Audit Log</a>
    </nav>
    <div class="sidebar-footer"><div class="env-badge">Sandbox · v1.0</div></div>
  </aside>
  <main class="main-content">
    <div class="topbar">
      <div class="topbar-left"><span class="topbar-breadcrumb">Operations → <span>Audit Log</span></span></div>
      <div class="topbar-right"><span class="topbar-clock" id="clock"></span></div>
    </div>
    <div class="page-content">
      <div class="page-header">
        <div><div class="page-title">Audit Log</div><div class="page-subtitle">ALL SYSTEM CHANGES · CREATE · UPDATE · DELETE</div></div>
        <button class="btn btn-secondary" onclick="load()">↻ Refresh</button>
      </div>
      <div class="card">
        <div class="card-header">
          <span class="card-title">🔍 Activity <span class="count-label" id="count"></span></span>
          <div class="search-bar" style="margin:0;width:220px"><span class="search-icon">🔎</span><input type="text" placeholder="Search logs..." id="search-input"></div>
        </div>
        <div class="table-wrapper">
          <table>
            <thead><tr><th>Timestamp</th><th>Action</th><th>Table</th><th>Record ID</th><th>Performed By</th></tr></thead>
            <tbody id="tbody"><tr><td colspan="5"><div class="empty-state"><div class="empty-icon">⏳</div><p>Loading...</p></div></td></tr></tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</div>
<script src="app.js"></script>
<script>
var records=[];
document.getElementById('search-input').addEventListener('input',render);
async function load(){
  try{records=await apiFetch('/api/audit');render();}
  catch(e){document.getElementById('tbody').innerHTML='<tr><td colspan="5"><div class="empty-state"><div class="empty-icon">⚠</div><p style="color:var(--red)">'+e.message+'</p></div></td></tr>';}
}
function render(){
  var q=document.getElementById('search-input').value.toLowerCase();
  var data=q?records.filter(function(r){return JSON.stringify(r).toLowerCase().includes(q);}):([].concat(records));
  document.getElementById('count').textContent='· '+data.length+' entries';
  var tbody=document.getElementById('tbody');
  if(!data.length){tbody.innerHTML='<tr><td colspan="5"><div class="empty-state"><div class="empty-icon">🔍</div><p>No audit entries yet — make some changes!</p></div></td></tr>';return;}
  var ac={CREATE:'var(--green)',UPDATE:'var(--accent)',DELETE:'var(--red)'};
  tbody.innerHTML=data.map(function(l){
    return'<tr>'+
    '<td class="mono" style="font-size:11px;color:var(--text3)">'+new Date(l.created_at).toLocaleString()+'</td>'+
    '<td><span style="font-weight:700;color:'+(ac[l.action]||'var(--text2)')+'">'+l.action+'</span></td>'+
    '<td style="font-size:12px;color:var(--text2)">'+l.table_name+'</td>'+
    '<td class="mono" style="font-size:10px;color:var(--text3)">'+l.record_id+'</td>'+
    '<td style="font-size:12px">'+l.performed_by+'</td>'+
    '</tr>';
  }).join('');
}
load();
</script>
</body>
</html>
